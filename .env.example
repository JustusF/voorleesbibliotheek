# Supabase configuratie (optioneel - voor database sync)
# Als deze niet zijn ingesteld, werkt de app nog steeds maar met alleen localStorage

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Server-only admin configuratie (Vercel env vars)
# ============================================

# Zet deze NIET met VITE_ prefix; de browser mag deze waarden niet zien.
# Genereer ADMIN_SECRET met bijvoorbeeld: openssl rand -base64 32
ADMIN_SECRET=your-random-server-only-session-secret

# SHA-256 hash van de 4-cijferige admin-pincode.
# Voorbeeld genereren: printf "1234" | shasum -a 256
ADMIN_PIN_HASH=your-sha256-pin-hash

# Optioneel: admin sessieduur in seconden (default: 900 = 15 minuten)
ADMIN_SESSION_TTL_SECONDS=900

# ============================================
# Audio Storage Backend Configuratie
# ============================================

# Kies je audio storage backend: 'supabase' (default) of 'r2'
# Als je Cloudflare R2 wilt gebruiken voor goedkopere audio opslag,
# zet dit op 'r2' en configureer de R2 variabelen hieronder
VITE_AUDIO_STORAGE_BACKEND=supabase

# Cloudflare R2 configuratie (alleen nodig als VITE_AUDIO_STORAGE_BACKEND=r2)
# VITE_R2_WORKER_URL is de URL van je Cloudflare Worker proxy
# VITE_R2_PUBLIC_URL is de public URL van je R2 bucket
#
# Setup instructies:
# 1. Maak een R2 bucket aan in Cloudflare Dashboard
# 2. Enable Public Access voor de bucket
# 3. Deploy de worker in workers/r2-audio-proxy/
# 4. Vul de URLs hieronder in

VITE_R2_WORKER_URL=https://voorleesbibliotheek-audio.your-subdomain.workers.dev
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ============================================
# Andere API Keys
# ============================================

# Anthropic API key voor OCR (Claude Vision) - inhoudsopgave scannen
# Dit wordt gebruikt door de Vercel serverless function
ANTHROPIC_API_KEY=your-anthropic-key-here
